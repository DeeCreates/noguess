<script>
    const generateBtn = document.getElementById('generateCoordBtn');
    const coordsInput = document.getElementById('offlineCoordinates');
    const locationStatus = document.getElementById('locationStatus');
    
    function getLocation() {
        if (!navigator.geolocation) {
            locationStatus.innerHTML = '<i class="fas fa-exclamation-triangle" style="color:#ff8888;"></i> Geolocation not supported. Please enter manually.';
            return;
        }
        generateBtn.disabled = true;
        generateBtn.innerHTML = '<i class="fas fa-spinner fa-pulse"></i> Getting location...';
        locationStatus.innerHTML = '<i class="fas fa-spinner fa-pulse"></i> Requesting location... Please allow access.';
        
        navigator.geolocation.getCurrentPosition(
            (position) => {
                const lat = position.coords.latitude.toFixed(6);
                const lng = position.coords.longitude.toFixed(6);
                const latDir = lat >= 0 ? 'N' : 'S';
                const lngDir = lng >= 0 ? 'E' : 'W';
                const coordsString = `${Math.abs(lat)}° ${latDir}, ${Math.abs(lng)}° ${lngDir}`;
                coordsInput.value = coordsString;
                locationStatus.innerHTML = '<i class="fas fa-check-circle" style="color:#f5c542;"></i> Location captured! Coordinates: ' + coordsString;
                generateBtn.innerHTML = '<i class="fas fa-check"></i> Captured!';
                setTimeout(() => { 
                    generateBtn.innerHTML = '<i class="fas fa-location-dot"></i> Get My Location'; 
                    generateBtn.disabled = false; 
                }, 2000);
            },
            (error) => {
                let msg = '';
                if(error.code === 1) msg = 'Permission denied. Please enable location access and try again.';
                else if(error.code === 2) msg = 'Location unavailable. Please enter coordinates manually.';
                else msg = 'Location timeout. Please try again.';
                locationStatus.innerHTML = '<i class="fas fa-exclamation-triangle" style="color:#ff8888;"></i> ' + msg;
                generateBtn.innerHTML = '<i class="fas fa-location-dot"></i> Get My Location';
                generateBtn.disabled = false;
            },
            { enableHighAccuracy: true, timeout: 10000 }
        );
    }
    generateBtn.addEventListener('click', getLocation);
    
    const amountSelect = document.getElementById('offlineAmount');
    const customAmount = document.getElementById('offlineCustomAmount');
    amountSelect.addEventListener('change', function() {
        if(this.value === 'other') {
            customAmount.style.display = 'block';
            customAmount.required = true;
        } else {
            customAmount.style.display = 'none';
            customAmount.required = false;
            customAmount.value = '';
        }
    });
    customAmount.style.display = 'none';
    
    const offlineForm = document.getElementById('offlineRequestForm');
    const offlineWrapper = document.getElementById('requestFormWrapper');
    const offlineSuccess = document.getElementById('offlineSuccessMsg');
    const offlineSubmitBtn = document.getElementById('offlineSubmitBtn');
    
    offlineForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const txId = document.getElementById('offlineTxId').value.trim();
        const coords = coordsInput.value.trim();
        if(!coords) { alert('Please enter coordinates or use "Get My Location"'); return; }
        if(!txId) { alert('Please enter MTN MoMo Transaction ID'); return; }
        
        document.getElementById('offlineTimestamp').value = new Date().toISOString();
        offlineSubmitBtn.disabled = true;
        offlineSubmitBtn.innerHTML = '<i class="fas fa-spinner fa-pulse"></i> Submitting...';
        
        const fd = new FormData(offlineForm);
        try {
            const res = await fetch(offlineForm.action, { method: 'POST', body: fd, headers: { 'Accept': 'application/json' } });
            if(res.ok) {
                const requestRecord = { coords, txId, timestamp: new Date().toISOString() };
                let requests = JSON.parse(localStorage.getItem('noguess_offline_requests') || '[]');
                requests.push(requestRecord);
                localStorage.setItem('noguess_offline_requests', JSON.stringify(requests));
                
                offlineWrapper.style.display = 'none';
                offlineSuccess.style.display = 'block';
                offlineForm.reset();
                customAmount.style.display = 'none';
                amountSelect.value = '';
            } else alert('Error submitting. Please try again or WhatsApp 0555556964');
        } catch(err) { alert('Network error. Please check your connection and try again.'); }
        finally { offlineSubmitBtn.disabled = false; offlineSubmitBtn.innerHTML = '<i class="fas fa-paper-plane"></i> Submit Request'; }
    });
    
    window.resetForm = function() {
        offlineWrapper.style.display = 'block';
        offlineSuccess.style.display = 'none';
        offlineForm.reset();
        customAmount.style.display = 'none';
        amountSelect.value = '';
        coordsInput.value = '';
        locationStatus.innerHTML = '<i class="fas fa-lightbulb"></i> Click "Get My Location" to auto-capture your current GPS coordinates.';
        document.getElementById('offlineTimestamp').value = new Date().toISOString();
    };
    
    if (window.location.hash === '#offline-success') {
        offlineWrapper.style.display = 'none';
        offlineSuccess.style.display = 'block';
    }
    
    if (/Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent)) {
        const hint = document.createElement('div');
        hint.style.cssText = 'background: rgba(245,197,66,0.1); padding: 8px 12px; border-radius: 12px; margin-top: 8px; font-size: 0.7rem; color: #f5c542; text-align: center;';
        hint.innerHTML = '<i class="fas fa-mobile-alt"></i> For best results, enable GPS/location services on your phone.';
        document.querySelector('.coord-input-group').after(hint);
    }
</script>
</body>
</html>
